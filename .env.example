BOT_TOKEN=123456:replace_me
BOT_USERNAME=your_bot_username
TELEGRAM_PAYMENT_PROVIDER_TOKEN=replace_with_provider_token_from_botfather
PAYMENT_PROVIDER=telegram
ADMIN_IDS=123456789,987654321

DATABASE_URL=postgresql+asyncpg://bot:bot_password@postgres:5432/digital_goods_bot
REDIS_URL=redis://redis:6379/0

CALLBACK_SECRET=change_me_to_32_bytes_random_string
PAYMENT_CURRENCY_DEFAULT=RUB
INVOICE_TTL_SECONDS=900

PLATEGA_BASE_URL=https://app.platega.io
PLATEGA_MERCHANT_ID=
PLATEGA_API_KEY=
# Empty value opens the universal Platega payment form through /v2/transaction/process.
# Payment methods from Platega docs: 2 SBP QR, 3 ERIP, 11 cards, 12 international cards, 13 crypto.
PLATEGA_PAYMENT_METHOD=
PLATEGA_RETURN_URL=
PLATEGA_FAILED_URL=
PLATEGA_CALLBACK_ENABLED=false

WEBHOOK_MODE=false
WEBHOOK_URL=
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
CREATE_TABLES_ON_STARTUP=false
MAINTENANCE_MODE=false

RATE_LIMIT_MESSAGES_PER_MINUTE=30
RATE_LIMIT_CALLBACKS_PER_MINUTE=60
ORDER_RATE_LIMIT_PER_HOUR=20

LOG_LEVEL=INFO
POSTGRES_DB=digital_goods_bot
POSTGRES_USER=bot
POSTGRES_PASSWORD=bot_password
